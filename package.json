{
	"engines": {
		"node": ">=20.10.0",
		"npm": ">=10.2.3"
	},
	"volta": {
		"node": "24.14.1"
	},
	"devDependencies": {
		"@wordpress/env": "^11.10.0",
		"@wordpress/scripts": "^32.3.0",
		"autoprefixer": "^10.5.2",
		"cpy-cli": "^7.0.0",
		"cssnano": "^8.0.2",
		"npm-run-all": "^4.1.5",
		"postcss": "^8.5.18",
		"postcss-cli": "^11.0.1",
		"postcss-import": "^16.1.1",
		"rimraf": "^6.1.3",
		"sass": "^1.101.0"
	},
	"scripts": {
		"export:wp-content:themes": "npm run cli cp -- -r ../../themes .export/wp-content",
		"export:wp-content:uploads": "npm run cli cp -- -r ../../uploads .export/wp-content",
		"export:wp-content": "npm run cli rm -- -rf .export/wp-content && mkdir -p .export/wp-content/uploads && run-p export:wp-content:*",
		"export:db": "mkdir -p .export/sql && npm run wp db -- export .export/sql/local.sql",
		"export": "run-p export:*",
		"import:wp-content:themes": "npm run cli cp -- -r .export/wp-content/themes ../../",
		"import:wp-content:uploads": "npm run cli cp -- -r .export/wp-content/uploads ../../",
		"import:wp-content": "run-p import:wp-content:*",
		"import:db": "npm run wp db -- import .export/sql/local.sql",
		"import": "run-p import:*",
		"wp-env": "wp-env",
		"start": "wp-env start && open http://localhost:8888",
		"stop": "npm run export && wp-env stop",
		"destroy": "wp-env destroy && wp-env destroy --config=.wp-env.tests.json",
		"cli": "wp-env run --env-cwd=wp-content/plugins/unitone-bbpress-integrator cli",
		"wp": "wp-env run --env-cwd=wp-content/plugins/unitone-bbpress-integrator cli wp",
		"composer": "wp-env run --env-cwd=wp-content/plugins/unitone-bbpress-integrator cli composer",
		"pretest": "wp-env start && npm run composer install",
		"test:php:start": "wp-env start --config=.wp-env.tests.json",
		"test-composer": "wp-env run --config=.wp-env.tests.json --env-cwd=wp-content/plugins/unitone-bbpress-integrator cli composer",
		"test:lint:blocks": "wp-scripts lint-js src/blocks",
		"pretest:php:lint": "npm run test:php:start && npm run test-composer -- install",
		"test:php:lint": "npm run test-composer -- lint",
		"posttest:php:lint": "wp-env stop --config=.wp-env.tests.json",
		"test:lint:php": "npm run test:php:lint",
		"test:lint": "run-s test:lint:*",
		"pretest:php:unit": "npm run test:php:start && npm run test-composer -- install && npm run test-composer -- install-theme && npm run test-composer -- install-plugin",
		"test:php:unit": "wp-env run --config=.wp-env.tests.json --env-cwd=wp-content/plugins/unitone-bbpress-integrator wordpress vendor/bin/phpunit -c .phpunit.xml.dist --verbose",
		"posttest:php:unit": "wp-env stop --config=.wp-env.tests.json",
		"test:unit:php": "npm run test:php:unit",
		"test:unit": "run-s test:unit:*",
		"test": "run-s test:*",
		"clean:css": "rimraf dist/css && mkdir -p dist/css",
		"clean:js": "rimraf dist/js && mkdir -p dist/js",
		"clean:zip": "rimraf unitone-bbpress-integrator.zip",
		"format:blocks": "wp-scripts format src/blocks",
		"format:js": "wp-scripts format src/js",
		"format": "run-p format:*",
		"css:app": "sass --no-source-map src/css/app.scss:dist/css/app.css && postcss dist/css/app.css -r",
		"css:like": "sass --no-source-map src/css/like.scss:dist/css/like.css && postcss dist/css/like.css -r",
		"css": "npm run clean:css && npm-run-all -p css:*",
		"js:like": "wp-scripts build src/js/like.js --output-path=dist/js",
		"js": "npm run clean:js && npm run format:js && run-p js:*",
		"blocks:build": "rimraf dist/blocks && wp-scripts build --output-path=dist --experimental-modules",
		"blocks:php": "cpy \"src/blocks/**/*.php\" \"dist/blocks\"",
		"blocks": "run-s format:blocks blocks:build blocks:php",
		"build": "npm-run-all -p css blocks js",
		"zip:pack": "rsync -a --exclude='/vendor' --exclude='/node_modules' --exclude='.*' --exclude='*.ruleset.xml' --exclude='*.config.js' --exclude='*.xml.dist' --exclude='/tests' --exclude='package*.json' . unitone-bbpress-integrator && wp-env start && npm run composer install -- --no-dev -d unitone-bbpress-integrator",
		"zip:archive": "zip -9 -qmr unitone-bbpress-integrator.zip unitone-bbpress-integrator",
		"zip": "npm run clean:zip && npm run zip:pack && npm run zip:archive",
		"make-pot": "npm run wp i18n -- make-pot . ./languages/unitone-bbpress-integrator.pot --exclude=.*,src",
		"make-json": "rimraf languages/*.json && npm run wp i18n -- make-json ./languages/unitone-bbpress-integrator-ja.po --no-purge",
		"make-php": "npm run cli php -- ./bin/l10n.php"
	}
}
